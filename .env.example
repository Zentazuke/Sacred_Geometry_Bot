# Copy to .env and fill in. The MVP (observer + research) needs NO keys —
# Binance public market data is keyless. Keys are only for Phase 9 testnet trading.

ENVIRONMENT=testnet
ALLOW_LIVE_TRADING=false

# Binance Spot TESTNET keys (https://testnet.binance.vision/). Leave blank for MVP.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
